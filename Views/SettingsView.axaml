<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HardwareMonitor.ViewModels"
             xmlns:conv="using:HardwareMonitor.Converters"
             x:Class="HardwareMonitor.Views.SettingsView"
             x:DataType="vm:MainViewModel">

  <UserControl.Resources>
    <conv:IntervalActiveConverter x:Key="IntervalActive"/>
    <conv:NavActiveConverter x:Key="NavActive"/>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,*">
    <!-- Header -->
    <Border Grid.Row="0" Background="#0d001a" BorderBrush="#2f006b" BorderThickness="0,0,0,1" Padding="32,20">
      <StackPanel Spacing="2">
        <TextBlock Text="SETTINGS" FontSize="11" Foreground="#8d59cf" FontWeight="Bold" LetterSpacing="2"/>
        <TextBlock Text="Configuration" FontSize="24" FontWeight="Bold" Foreground="#ffffff"/>
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1">
    <StackPanel Margin="32,20,32,32" Spacing="24" MaxWidth="560">

      <!-- ═══ Startup & System Tray ═══ -->
      <Border Classes="card" Padding="24">
        <StackPanel Spacing="14">
          <TextBlock Text="STARTUP &amp; SYSTEM TRAY" FontSize="10" Foreground="#8d59cf" FontWeight="Bold" LetterSpacing="2"/>
          <Separator/>
          <Grid ColumnDefinitions="*,Auto" Margin="0,4">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="Launch at startup" FontSize="13" Foreground="#ffffff"/>
              <TextBlock Text="Automatically start with your system" FontSize="11" Foreground="#7a7977"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoStartEnabled}"
                          OnContent="ON" OffContent="OFF" VerticalAlignment="Center"/>
          </Grid>
          <Grid ColumnDefinitions="*,Auto" Margin="0,4">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="Start minimized" FontSize="13" Foreground="#ffffff"/>
              <TextBlock Text="Launch directly to system tray" FontSize="11" Foreground="#7a7977"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding StartMinimized}"
                          OnContent="ON" OffContent="OFF" VerticalAlignment="Center"/>
          </Grid>
          <Grid ColumnDefinitions="*,Auto" Margin="0,4">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="Minimize to tray" FontSize="13" Foreground="#ffffff"/>
              <TextBlock Text="Hide to system tray instead of taskbar" FontSize="11" Foreground="#7a7977"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding MinimizeToTray}"
                          OnContent="ON" OffContent="OFF" VerticalAlignment="Center"/>
          </Grid>
          <Grid ColumnDefinitions="*,Auto" Margin="0,4">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="Close to tray" FontSize="13" Foreground="#ffffff"/>
              <TextBlock Text="Keep running in background when closed" FontSize="11" Foreground="#7a7977"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding CloseToTray}"
                          OnContent="ON" OffContent="OFF" VerticalAlignment="Center"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ═══ Tray Icon Display ═══ -->
      <Border Classes="card" Padding="24">
        <StackPanel Spacing="14">
          <TextBlock Text="TRAY ICON DISPLAY" FontSize="10" Foreground="#8d59cf" FontWeight="Bold" LetterSpacing="2"/>
          <Separator/>
          <TextBlock Text="Choose what the system tray icon shows" FontSize="12" Foreground="#b0b0b0" Margin="0,0,0,4"/>
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Classes="navBtn" Margin="0,0,8,8" Command="{Binding SetTrayIconModeCommand}" CommandParameter="AppIcon"
                    Background="{Binding TrayIconMode, Converter={StaticResource NavActive}, ConverterParameter=AppIcon}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="HM" FontWeight="Bold" FontSize="12" Foreground="#00ffec"/>
                <TextBlock Text="App Icon" FontSize="12"
                           Foreground="{Binding TrayIconMode, Converter={StaticResource NavActive}, ConverterParameter=AppIcon|fg}"/>
              </StackPanel>
            </Button>
            <Button Classes="navBtn" Margin="0,0,8,8" Command="{Binding SetTrayIconModeCommand}" CommandParameter="CpuTemp"
                    Background="{Binding TrayIconMode, Converter={StaticResource NavActive}, ConverterParameter=CpuTemp}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="🌡" FontSize="12"/>
                <TextBlock Text="CPU Temp" FontSize="12"
                           Foreground="{Binding TrayIconMode, Converter={StaticResource NavActive}, ConverterParameter=CpuTemp|fg}"/>
              </StackPanel>
            </Button>
            <Button Classes="navBtn" Margin="0,0,8,8" Command="{Binding SetTrayIconModeCommand}" CommandParameter="GpuTemp"
                    Background="{Binding TrayIconMode, Converter={StaticResource NavActive}, ConverterParameter=GpuTemp}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="🌡" FontSize="12"/>
                <TextBlock Text="GPU Temp" FontSize="12"
                           Foreground="{Binding TrayIconMode, Converter={StaticResource NavActive}, ConverterParameter=GpuTemp|fg}"/>
              </StackPanel>
            </Button>
            <Button Classes="navBtn" Margin="0,0,8,8" Command="{Binding SetTrayIconModeCommand}" CommandParameter="CpuLoad"
                    Background="{Binding TrayIconMode, Converter={StaticResource NavActive}, ConverterParameter=CpuLoad}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="📊" FontSize="12"/>
                <TextBlock Text="CPU Load" FontSize="12"
                           Foreground="{Binding TrayIconMode, Converter={StaticResource NavActive}, ConverterParameter=CpuLoad|fg}"/>
              </StackPanel>
            </Button>
            <Button Classes="navBtn" Margin="0,0,8,8" Command="{Binding SetTrayIconModeCommand}" CommandParameter="GpuLoad"
                    Background="{Binding TrayIconMode, Converter={StaticResource NavActive}, ConverterParameter=GpuLoad}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="📊" FontSize="12"/>
                <TextBlock Text="GPU Load" FontSize="12"
                           Foreground="{Binding TrayIconMode, Converter={StaticResource NavActive}, ConverterParameter=GpuLoad|fg}"/>
              </StackPanel>
            </Button>
          </WrapPanel>
          <TextBlock FontSize="11" Foreground="#7a7977">
            <Run Text="Current: "/>
            <Run Text="{Binding TrayIconMode}" Foreground="#00ffec"/>
            <Run Text=" — the tray icon will show the live value as a number"/>
          </TextBlock>
        </StackPanel>
      </Border>

      <!-- Monitoring Categories -->
      <Border Classes="card" Padding="24">
        <StackPanel Spacing="14">
          <TextBlock Text="MONITORING CATEGORIES" FontSize="10" Foreground="#8d59cf" FontWeight="Bold" LetterSpacing="2"/>
          <Separator/>
          <CheckBox Content="CPU" IsChecked="{Binding CpuEnabled}"/>
          <CheckBox Content="GPU" IsChecked="{Binding GpuEnabled}"/>
          <CheckBox Content="Memory" IsChecked="{Binding MemoryEnabled}"/>
          <CheckBox Content="Motherboard" IsChecked="{Binding MotherboardEnabled}"/>
          <CheckBox Content="Storage" IsChecked="{Binding StorageEnabled}"/>
          <CheckBox Content="Network" IsChecked="{Binding NetworkEnabled}"/>
          <CheckBox Content="Battery" IsChecked="{Binding BatteryEnabled}"/>
          <CheckBox Content="Controller" IsChecked="{Binding ControllerEnabled}"/>
          <CheckBox Content="PSU" IsChecked="{Binding PsuEnabled}"/>
        </StackPanel>
      </Border>

      <!-- Update Interval -->
      <Border Classes="card" Padding="24">
        <StackPanel Spacing="14">
          <TextBlock Text="UPDATE INTERVAL" FontSize="10" Foreground="#8d59cf" FontWeight="Bold" LetterSpacing="2"/>
          <Separator/> 
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="500ms" Command="{Binding SetIntervalCommand}" CommandParameter="500"
                    Classes="intervalBtn"
                    Background="{Binding UpdateInterval, Converter={StaticResource IntervalActive}, ConverterParameter=500}"
                    Foreground="{Binding UpdateInterval, Converter={StaticResource IntervalActive}, ConverterParameter=500|fg}"/>
            <Button Content="1s" Command="{Binding SetIntervalCommand}" CommandParameter="1000"
                    Classes="intervalBtn"
                    Background="{Binding UpdateInterval, Converter={StaticResource IntervalActive}, ConverterParameter=1000}"
                    Foreground="{Binding UpdateInterval, Converter={StaticResource IntervalActive}, ConverterParameter=1000|fg}"/>
            <Button Content="2s" Command="{Binding SetIntervalCommand}" CommandParameter="2000"
                    Classes="intervalBtn"
                    Background="{Binding UpdateInterval, Converter={StaticResource IntervalActive}, ConverterParameter=2000}"
                    Foreground="{Binding UpdateInterval, Converter={StaticResource IntervalActive}, ConverterParameter=2000|fg}"/>
            <Button Content="5s" Command="{Binding SetIntervalCommand}" CommandParameter="5000"
                    Classes="intervalBtn"
                    Background="{Binding UpdateInterval, Converter={StaticResource IntervalActive}, ConverterParameter=5000}"
                    Foreground="{Binding UpdateInterval, Converter={StaticResource IntervalActive}, ConverterParameter=5000|fg}"/>
          </StackPanel>
          <TextBlock Text="{Binding UpdateInterval, StringFormat='Current: {0}ms'}" Foreground="#7a7977" FontSize="11"/>
        </StackPanel>
      </Border>

      <!-- About -->
      <Border Classes="card" Padding="24">
        <StackPanel Spacing="10">
          <TextBlock Text="ABOUT" FontSize="10" Foreground="#8d59cf" FontWeight="Bold" LetterSpacing="2"/>
          <Separator/>
          <TextBlock Text="Hardware Monitor" FontSize="16" FontWeight="SemiBold" Foreground="#ffffff"/>
          <TextBlock Text="Avalonia UI · LibreHardwareMonitorLib · Native AOT" Foreground="#7a7977" FontSize="12"/>
        </StackPanel>
      </Border>

    </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
