<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HardwareMonitor.ViewModels"
             xmlns:conv="using:HardwareMonitor.Converters"
             x:Class="HardwareMonitor.Views.MemoryDetailView"
             x:DataType="vm:MainViewModel">

  <UserControl.Resources>
    <conv:LoadToColorConverter x:Key="LoadToColor"/>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,*">
    <!-- Header -->
    <Border Grid.Row="0" Background="#0d001a" BorderBrush="#2f006b" BorderThickness="0,0,0,1" Padding="32,20">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <Button Classes="ghostBtn" Content="‹ Back" Grid.Column="0"
                Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"
                VerticalAlignment="Center" Margin="0,0,16,0"/>
        <StackPanel Grid.Column="1" Spacing="2">
          <TextBlock Text="MEMORY" Foreground="#8d59cf" FontSize="11" FontWeight="Bold" LetterSpacing="2"/>
          <TextBlock Text="System RAM" FontSize="24" FontWeight="Bold" Foreground="#ffffff"/>
        </StackPanel>
        <!-- Quick usage -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
          <StackPanel HorizontalAlignment="Center" Spacing="2">
            <TextBlock Text="USED" FontSize="9" Foreground="#7a7977" FontWeight="Bold" LetterSpacing="1" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding MemDetailUsed}" FontSize="18" FontWeight="Bold" Foreground="#ffa42c" HorizontalAlignment="Center"/>
          </StackPanel>
          <StackPanel HorizontalAlignment="Center" Spacing="2">
            <TextBlock Text="AVAILABLE" FontSize="9" Foreground="#7a7977" FontWeight="Bold" LetterSpacing="1" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding MemDetailAvailable}" FontSize="18" FontWeight="Bold" Foreground="#00ffec" HorizontalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1">
      <StackPanel Margin="32,20,32,32" Spacing="24">

        <!-- ═══ Overall Usage ═══ -->
        <Border Classes="card" Padding="24,18">
          <StackPanel Spacing="10">
            <TextBlock Text="OVERALL USAGE" FontSize="10" Foreground="#7a7977" FontWeight="Bold" LetterSpacing="2"/>
            <Grid ColumnDefinitions="*,Auto">
              <ProgressBar Minimum="0" Maximum="100" Value="{Binding MemDetailLoad}" Height="10"
                           Foreground="{Binding MemDetailLoad, Converter={StaticResource LoadToColor}}"
                           Background="#0d001a"/>
              <TextBlock Grid.Column="1" Text="{Binding MemLoadText}" FontSize="20" FontWeight="Bold"
                         Foreground="#ffffff" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </Grid>
            <TextBlock Text="{Binding MemUsedText}" FontSize="12" Foreground="#7a7977"/>
          </StackPanel>
        </Border>

        <!-- ═══ Installed DIMMs ═══ -->
        <StackPanel Spacing="10">
          <TextBlock Text="INSTALLED DIMMS" FontSize="10" Foreground="#7a7977" FontWeight="Bold" LetterSpacing="2"/>
          <ItemsControl ItemsSource="{Binding DimmItems}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:DimmItem">
                <Border Classes="card" Margin="0,0,0,8" Padding="24,16">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="6">
                      <!-- DIMM name (manufacturer - part number) -->
                      <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff"
                                 TextTrimming="CharacterEllipsis"/>

                      <!-- Speed & Type row -->
                      <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock FontSize="12" Foreground="#00ffec" FontWeight="SemiBold"
                                   Text="{Binding SpeedText}"/>
                        <TextBlock FontSize="12" Foreground="#ffa42c" FontWeight="SemiBold"
                                   Text="{Binding TimingsText}"/>
                      </StackPanel>

                      <!-- Details row -->
                      <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock FontSize="11" Foreground="#7a7977">
                          <Run Text="Capacity: "/>
                          <Run Text="{Binding Capacity}" Foreground="#a5a29d"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="#7a7977">
                          <Run Text="Voltage: "/>
                          <Run Text="{Binding Voltage}" Foreground="#a5a29d"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="#7a7977">
                          <Run Text="Latency: "/>
                          <Run Text="{Binding CasLatency}" Foreground="#a5a29d"/>
                        </TextBlock>
                      </StackPanel>
                    </StackPanel>

                    <!-- Temperature -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <TextBlock Text="TEMP" FontSize="8" Foreground="#7a7977" FontWeight="Bold"
                                 LetterSpacing="1" HorizontalAlignment="Center"/>
                      <TextBlock Text="{Binding Temp}" FontSize="20" FontWeight="Bold"
                                 Foreground="#ffa42c" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
